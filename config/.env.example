# Copy this file to .env and fill in real values locally.
# .env is gitignored — it must never be committed.
# This file (.env.example) contains no real values and is safe to commit.

# Google Cloud project to use for BigQuery. Never hardcode this in source
# code — every script must read it from this variable. This is YOUR
# billing/query-execution project, distinct from the "nyu-datasets"
# project that hosts the source tables below.
GCP_PROJECT_ID=

# BigQuery dataset names (left blank here; decide and document in DECISIONS.md
# once Stage 4 — BigQuery Loading — begins).
BQ_RAW_DATASET=
BQ_STAGING_DATASET=
BQ_MARTS_DATASET=

# Authentication: Stage 2's BigQuery extraction foundation uses
# Application Default Credentials only. Run
# `gcloud auth application-default login` locally before running
# scripts/validate_source_metadata.py. Service-account key files are
# intentionally not supported or referenced anywhere in this project.

# Fully-qualified source table IDs (non-secret — these name a shared,
# read-only teaching dataset, not anything belonging to you). Leave
# blank to use the verified Stage 1 defaults baked into
# src/extraction/config.py; override only to point at a different table.
BQ_CITIBIKE_TABLE=
BQ_WEATHER_TABLE=

# BigQuery job location for query execution. Defaults to "US" if unset
# (see src/extraction/config.py).
BQ_LOCATION=

# Name/location of the provided daily weather table (BigQuery
# project.dataset.table). Confirmed in Stage 1 — see DECISIONS.md D-005
# and BQ_WEATHER_TABLE above (this field is kept for historical
# reference; BQ_WEATHER_TABLE is what the code actually reads).
WEATHER_TABLE=

# --- Stage 3: one-month (January 2025) ETL prototype -----------------
# Destination for scripts/run_prototype_january_2025.py. This is YOUR
# OWN project/dataset — never the "nyu-datasets" source project. The
# dataset must already exist; it is never auto-created.

# Defaults to GCP_PROJECT_ID above if left blank.
BQ_DESTINATION_PROJECT_ID=

# Required — no default. Must name an existing dataset in the
# destination project.
BQ_DESTINATION_DATASET=
